{
  "headers": [
    {
      "source": "**/*.@(js|css|webp|svg|png|jpg|jpeg)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/shop",
      "destination": "/ayurvedic-products",
      "type": 301
    },
    {
      "source": "/about",
      "destination": "/about-ayurvedic-doctor-in-solan",
      "type": 301
    }
  ],
  "rewrites": [
    {
      "source": "**",
      "destination": "/index.html"
    }
  ]
}
